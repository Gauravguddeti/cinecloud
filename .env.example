# ─────────────────────────────────────────────────────────────────
#  CineCloud Backend — Environment Variables (GCP)
#  Copy to .env and fill in your values.
#  NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────

# GCP Project ID — from console.cloud.google.com
GCP_PROJECT_ID=your-gcp-project-id

# Firebase Web API Key — Firebase Console → Project Settings → Web API Key
FIREBASE_WEB_API_KEY=AIzaSy_your_firebase_web_api_key

# TMDB API key v3 — get free at https://developer.themoviedb.org
TMDB_API_KEY=your_tmdb_api_key_here

# Upstash Redis connection URL — Upstash Console → your Redis DB → "Redis URL"
# (NOT the REST API key — looks like: redis://default:PASSWORD@endpoint.upstash.io:6379)
REDIS_URL=redis://default:your_password@your-endpoint.upstash.io:6379

# Path to your GCP Service Account JSON key (for local testing only)
# Cloud Functions use Application Default Credentials automatically
GOOGLE_APPLICATION_CREDENTIALS=~/.gcloud/cinecloud-key.json
