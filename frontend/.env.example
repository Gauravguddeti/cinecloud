# CineCloud Frontend — Environment Variables (Render + Firebase)
# Copy to .env.local and fill in values after deploying backend to Render
#
# Firebase config: Firebase Console → Project Settings → Your Apps → Web App

# ── Render.com Backend URL ────────────────────────────────────
# Paste your Render service URL here (from render.com dashboard after deploy)
NEXT_PUBLIC_API_URL=https://cinecloud-api.onrender.com

# ── Firebase Web App Config ───────────────────────────────────
# Firebase Console → Project Settings → Your Apps → Web → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cinecloud-489619-f8782.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cinecloud-489619-f8782
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cinecloud-489619-f8782.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxx
